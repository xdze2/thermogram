{
  "$schema": "https://json-schema.org/draft/2020-12",
  "$id": "thermogram/material",
  "title": "Material",
  "description": "Physical thermal constants for a homogeneous building material.",
  "type": "object",
  "required": ["id", "name", "lambda", "rho", "cp"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier, used in assembly layer references.",
      "examples": ["stone_calcaire", "brick_full", "glass_double"]
    },
    "name": {
      "type": "string",
      "description": "Human-readable name.",
      "examples": ["Calcaire (pierre de taille)", "Brique pleine", "Double vitrage"]
    },
    "lambda": {
      "type": "number",
      "description": "Thermal conductivity [W/(m·K)].",
      "exclusiveMinimum": 0,
      "examples": [1.7, 0.8, 1.0]
    },
    "rho": {
      "type": "number",
      "description": "Density [kg/m³].",
      "exclusiveMinimum": 0,
      "examples": [2200, 1800, 2500]
    },
    "cp": {
      "type": "number",
      "description": "Specific heat capacity [J/(kg·K)].",
      "exclusiveMinimum": 0,
      "examples": [900, 840, 750]
    },
    "category": {
      "type": "string",
      "description": "Material category for library browsing.",
      "enum": ["masonry", "insulation", "wood", "concrete", "plaster", "glazing", "other"],
      "examples": ["masonry", "insulation"]
    },
    "source": {
      "type": "string",
      "description": "Reference for the values (standard, handbook, measurement).",
      "examples": ["ISO 10456:2007 Table 1", "CSTB", "measured"]
    },
    "notes": {
      "type": "string",
      "description": "Free-text notes, uncertainty caveats, regional variants."
    }
  }
}
